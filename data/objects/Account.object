    </fields>
    <fields>
        <fullName>vsa__Power_Map_Contacts_RO__c</fullName>
        <deprecated>false</deprecated>
        <externalId>false</externalId>
        <formula>HYPERLINK(&quot;/lightning/r/&quot;&amp; CASESAFEID(Id) &amp;&quot;/view&quot;,
(CASE( vsa__Count_of_Power_Map_Contacts__c,
0,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__NoPowerMapIcon&quot;, &quot;No Power Map&quot; , 50, 50)),
1,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap1&quot;, &quot;1 Power Map Contact&quot; , 50, 50)),
2,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap2&quot;, &quot;2 Power Map Contacts&quot; , 50, 50)),
3,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap3&quot;, &quot;3 Power Map Contacts&quot; , 50, 50)),
4,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap4&quot;, &quot;4 Power Map Contacts&quot; , 50, 50)),
5,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap5&quot;, &quot;5 Power Map Contacts&quot; , 50, 50)),
(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__PowerMap6&quot;, &quot;More than 5 Power Map Contacts&quot; , 50, 50))
))
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Power Map Contacts</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
