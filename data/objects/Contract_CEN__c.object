        <excludedStandardButtons>OpenListInQuip</excludedStandardButtons>
        <excludedStandardButtons>NewFromDocument</excludedStandardButtons>
        <excludedStandardButtons>Accept</excludedStandardButtons>
        <excludedStandardButtons>ChangeOwner</excludedStandardButtons>
        <excludedStandardButtons>Import</excludedStandardButtons>
        <excludedStandardButtons>MassChangeOwner</excludedStandardButtons>
        <excludedStandardButtons>PrintableListView</excludedStandardButtons>
        <excludedStandardButtons>MassAssignRecordLabel</excludedStandardButtons>
        <searchResultsAdditionalFields>Type__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Name__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Auto_Renew__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Billing_Cycle__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Billing_Start_Date__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Contract_Term__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Contract__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Energy_Program__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Organization_Name__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>Lock_Signed_Contract_Expect_OpsLead</fullName>
        <active>true</active>
        <description>Locks signed contracts for everyone expect System Admin and Kelli S (Operations Lead).</description>
        <errorConditionFormula>AND ( PRIORVALUE ( Contract_Status__c ) &lt;&gt; &quot;Draft&quot;,
NOT (
OR ( $Profile.Name = &quot;System Administrator&quot;,
$User.Email = &quot;dvanwinkle@cenergistic.com&quot;,
$User.Email = &quot;ksyrus@cenergistic.com&quot;,
$User.Email = &quot;mcaruso@cenergistic.com&quot; )
)
)</errorConditionFormula>
        <errorMessage>This Contract is locked. Please contact Operations Lead or CRM Admin if you have any questions.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Require_Auto_Renew_Cancelation_Deadline</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
  ISPICKVAL(Auto_Renew__c, &quot;Yes&quot;),
  ISBLANK(Auto_Renew_Cancelation_Deadline__c)
)</errorConditionFormula>
        <errorDisplayField>Auto_Renew_Cancelation_Deadline__c</errorDisplayField>
        <errorMessage>Auto Renew Cancellation Deadline is required.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
