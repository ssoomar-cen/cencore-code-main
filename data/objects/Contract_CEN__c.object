    <listViews>
        <fullName>Contracts_Analysis_Shams</fullName>
        <columns>NAME</columns>
        <columns>Billing_Schedule_End_Date__c</columns>
        <columns>Contract__c</columns>
        <columns>Contract_Status__c</columns>
        <columns>Contract_Type__c</columns>
        <columns>Name__c</columns>
        <columns>Organization_Name__c</columns>
        <columns>Energy_Program__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Energy_Program__c</field>
            <operation>equals</operation>
        </filters>
        <filters>
            <field>Contract_Status__c</field>
            <operation>equals</operation>
            <value>Active,Expired,Terminated</value>
        </filters>
        <filters>
            <field>Type__c</field>
            <operation>equals</operation>
            <value>Contract</value>
        </filters>
        <filters>
            <field>Name__c</field>
            <operation>notContain</operation>
            <value>Example</value>
        </filters>
        <filters>
            <field>Name__c</field>
            <operation>notContain</operation>
            <value>School of Energy</value>
        </filters>
        <filters>
            <field>Name__c</field>
            <operation>notEqual</operation>
            <value>NULL</value>
        </filters>
        <filters>
            <field>Name__c</field>
            <operation>notContain</operation>
            <value>Test</value>
        </filters>
        <label>Contracts missing Energy Programs</label>
    </listViews>
