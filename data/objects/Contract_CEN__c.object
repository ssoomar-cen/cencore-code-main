    <fields>
        <fullName>Billing_Term_Calc__c</fullName>
        <externalId>false</externalId>
        <formula>IF(
    OR(
        ISBLANK(Billable_Term__c),
        Billable_Term__c = 0
    ),
    Contract_Term__c -
    (
        (YEAR(Billing_Start_Date__c) - YEAR(Contract_Start_Date__c)) * 12 +
        (MONTH(Billing_Start_Date__c) - MONTH(Contract_Start_Date__c))
    ),
    Billable_Term__c
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Billing Term (Calc)</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
