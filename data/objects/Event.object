    <listViews>
        <fullName>My_Appointments_Past_14_Days</fullName>
        <columns>DUE_DATE</columns>
        <columns>Status__c</columns>
        <columns>SUBJECT</columns>
        <columns>Visit_Type__c</columns>
        <columns>WHO_NAME</columns>
        <columns>WHAT_NAME</columns>
        <columns>CORE.USERS.ALIAS</columns>
        <filterScope>Mine</filterScope>
        <filters>
            <field>DUE_DATE</field>
            <operation>equals</operation>
            <value>LAST_N_DAYS:14</value>
        </filters>
        <label>My Appointments Past 14 Days</label>
    </listViews>
    <listViews>
        <fullName>My_Appointments_This_Week</fullName>
        <columns>DUE_DATE</columns>
        <columns>Status__c</columns>
        <columns>SUBJECT</columns>
        <columns>Visit_Type__c</columns>
        <columns>WHO_NAME</columns>
        <columns>WHAT_NAME</columns>
        <columns>CORE.USERS.ALIAS</columns>
        <filterScope>Mine</filterScope>
        <filters>
            <field>DUE_DATE</field>
            <operation>greaterThan</operation>
            <value>12/31/2025 12:00 AM</value>
        </filters>
        <label>My Appointments This Week</label>
    </listViews>
    <listViews>
        <fullName>Open_Appointments_Last_90_Days</fullName>
        <columns>CORE.USERS.FULL_NAME</columns>
        <columns>SUBJECT</columns>
        <columns>DUE_DATE</columns>
        <columns>WHAT_NAME</columns>
        <columns>Visit_Type__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Status__c</field>
            <operation>equals</operation>
            <value>Open</value>
        </filters>
        <filters>
            <field>DUE_DATE</field>
            <operation>equals</operation>
            <value>LAST_90_DAYS</value>
        </filters>
        <filters>
            <field>Type__c</field>
            <operation>equals</operation>
            <value>Client Visit</value>
        </filters>
        <filters>
            <field>DUE_DATE</field>
            <operation>lessThan</operation>
            <value>TODAY</value>
        </filters>
        <label>Open Appointments Last 90 Days</label>
        <sharedTo>
            <role>Leadership_Team</role>
            <role>Operations_Team</role>
        </sharedTo>
    </listViews>
    <listViews>
        <fullName>Sales_Upcoming_Events</fullName>
        <columns>START_DATE_TIME</columns>
        <columns>END_DATE_TIME</columns>
        <columns>SUBJECT</columns>
        <columns>CORE.USERS.ALIAS</columns>
        <columns>Type__c</columns>
        <columns>Visit_Type__c</columns>
        <columns>Contact_Method__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>DUE_DATE</field>
            <operation>equals</operation>
            <value>TODAY,NEXT_N_DAYS:60</value>
        </filters>
        <filters>
            <field>Assigned_Name__c</field>
            <operation>equals</operation>
            <value>Cari Dubose</value>
        </filters>
        <label>Sales Upcoming Events</label>
    </listViews>
    <listViews>
        <fullName>Test_EP_Calendar</fullName>
        <columns>SUBJECT</columns>
        <columns>Status__c</columns>
        <columns>START_DATE_TIME</columns>
        <columns>END_DATE_TIME</columns>
        <columns>WHO_NAME</columns>
        <columns>WHAT_NAME</columns>
        <columns>CORE.USERS.ALIAS</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>WHAT_NAME</field>
            <operation>contains</operation>
            <value>First</value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operation>equals</operation>
            <value>Open</value>
        </filters>
        <label>Our First Energy Program</label>
    </listViews>
    <listViews>
        <fullName>TodaysAgenda</fullName>
        <columns>START_DATE_TIME</columns>
        <columns>END_DATE_TIME</columns>
        <columns>SUBJECT</columns>
        <columns>WHO_NAME</columns>
        <columns>WHAT_NAME</columns>
        <columns>CORE.USERS.ALIAS</columns>
        <columns>ALL_DAY</columns>
        <filterScope>Mine</filterScope>
        <filters>
            <field>DUE_DATE</field>
            <operation>lessOrEqual</operation>
            <value>TODAY</value>
        </filters>
        <filters>
            <field>END_DATE</field>
            <operation>greaterOrEqual</operation>
            <value>TODAY</value>
        </filters>
        <label>Today&apos;s Agenda</label>
    </listViews>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Client_Visit_or_Ops_Type_EP_only</fullName>
        <active>false</active>
        <description>Enforces using a related Energy Program for Type Client Visit or Operations</description>
        <errorConditionFormula>AND (
	ISPICKVAL (  Type__c , &quot;Client Visit&quot;),
	  ISBLANK( Energy_Program_Lookup__c ))</errorConditionFormula>
        <errorMessage>A Client Visit appointment must be related to an Energy Program. Choose from the Energy Program Lookup field.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Contact_Method_Requirement</fullName>
        <active>false</active>
        <description>Jira SF-378</description>
        <errorConditionFormula>AND(
    ISPICKVAL(Type__c, &quot;Sales&quot;),
    ISBLANK(TEXT(Contact_Method__c))
)</errorConditionFormula>
        <errorMessage>A Sales appointment requires a Contact Method.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Sales_Type_Opportunity_Only</fullName>
        <active>false</active>
        <description>Deactivated 2025Mar21 as per request by Kelli Sin Go Live tracking doc. If not used, delete from SF after May 2025.</description>
        <errorConditionFormula>AND (
ISPICKVAL ( Type__c , &quot;Sales&quot;),
LEFT (WhatId, 3 ) &lt;&gt; &quot;006&quot;,
LEFT (WhatId, 3 ) &lt;&gt; &quot;001&quot;,
LEFT (WhatId, 3 ) &lt;&gt; &quot;a0d&quot;
)</errorConditionFormula>
        <errorMessage>A Sales appointment must be related to an Energy Program, Organization or Opportunity. In the Related To section, select one of Energy Program, Organization or Opportunity from the drop down and then select the desired record.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Visit_Length_Requirement</fullName>
        <active>false</active>
        <description>If Type is Client Visit then Visit Length needs a value.</description>
        <errorConditionFormula>TEXT(Visit_Length__c) = &quot;&quot; &amp;&amp; TEXT(Type__c) = &quot;Client Visit&quot;</errorConditionFormula>
        <errorDisplayField>Visit_Length__c</errorDisplayField>
        <errorMessage>Please choose a value for Visit Length.</errorMessage>
    </validationRules>
</CustomObject>
