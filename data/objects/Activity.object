    <fields>
        <fullName>Visit_Length_Days__c</fullName>
        <externalId>false</externalId>
        <formula>CASE(Visit_Length__c,
    &quot;1/8 Day&quot;,                    0.125,
    &quot;1/4 Day&quot;,                    0.25,
    &quot;1/3 Day (3 visits per day)&quot;, 0.333,
    &quot;1/2 Day&quot;,                    0.5,
    &quot;3/4 Day&quot;,                    0.75,
    &quot;1 Full Day&quot;,                 1.0,
    &quot;1 1/2 Day&quot;,                  1.5,
    &quot;2 Full Days&quot;,                2.0,
    &quot;2 1/2 Day&quot;,                  2.5,
    &quot;3 Full Days&quot;,                3.0,
    &quot;4 Full Days&quot;,                4.0,
    &quot;5 Full Days&quot;,                5.0,
    ActivityDate - ActivityDate + 1
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Visit Length Days</label>
        <precision>18</precision>
        <required>false</required>
        <scale>3</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
