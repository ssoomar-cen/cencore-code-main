    <fields>
        <fullName>SharePoint_Path_URL__c</fullName>
        <externalId>false</externalId>
        <formula>HYPERLINK(
  &quot;https://cenergistic.sharepoint.com/sites/D365Sales/account/Forms/AllItems.aspx?id=&quot; &amp;
  /* Encode the server-relative path for the id= parameter (safe order, % first) */
  SUBSTITUTE(
    SUBSTITUTE(
      SUBSTITUTE(
        SUBSTITUTE(
          SUBSTITUTE(
            SUBSTITUTE(
              &quot;/sites/D365Sales/account/&quot; &amp;
              Account.SharePoint_Path__c &amp;
              &quot;/opportunity/&quot; &amp;
              IF(
                AND(
                  ISBLANK(D365OpportunityGuid__c),
                  DATEVALUE(CreatedDate) &gt; DATE(2025, 3, 10)
                ),
                /* Use 15-char Id (NOT CASESAFEID) */
                Name &amp; &quot;_&quot; &amp; Id,
                Name &amp; &quot;_&quot; &amp; D365OpportunityGuid__c
              ),
              &quot;%&quot;, &quot;%25&quot;   /* encode % first */
            ),
            &quot; &quot;, &quot;%20&quot;
          ),
          &quot;&amp;&quot;, &quot;%26&quot;
        ),
        &quot;#&quot;, &quot;%23&quot;
      ),
      &quot;?&quot;, &quot;%3F&quot;
    ),
    &quot;+&quot;, &quot;%2B&quot;
  ),
  &quot;Open in SharePoint&quot;,
  &quot;_blank&quot;
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>SharePoint Path URL</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SharePoint_Path__c</fullName>
        <externalId>false</externalId>
        <formula>Account.SharePoint_Path__c +&quot;/&quot;+&quot;opportunity&quot;+&quot;/&quot;+

IF ( AND (  ISBLANK ( D365OpportunityGuid__c ),  DATEVALUE( CreatedDate ) &gt; DATE ( 2025,3,10 ) ), 
Name + &quot;_&quot; +  Id , 
Name + &quot;_&quot; +  D365OpportunityGuid__c )</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Used for PDF Butler SharePoint integration to determine path to SharePoint file location.</inlineHelpText>
        <label>SharePoint Path</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
