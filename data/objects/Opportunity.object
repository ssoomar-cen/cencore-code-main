    <sharingModel>Read</sharingModel>
    <validationRules>
        <fullName>Closed_Won_Restriction</fullName>
        <active>true</active>
        <description>Only certain people can mark an Opportunity Closed Won</description>
        <errorConditionFormula>AND (  ISPICKVAL ( StageName, &quot;Closed Won&quot; ) ,
	NOT ( 
		OR (  $Profile.Name = &quot;System Administrator&quot;,
		$User.Email = &quot;dvanwinkle@cenergistic.com&quot;,
		$User.Email = &quot;mdwivedi@cenergistic.com&quot;,
		$User.Email = &quot;mcaruso@cenergistic.com&quot;
		) 
	)
)</errorConditionFormula>
        <errorMessage>Please contact Sales Operations and they will mark the Opportunity Closed Won</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Enter_Loss_Information</fullName>
        <active>true</active>
        <description>Require Loss fields to be completed when Stage goes to Closed Lost</description>
        <errorConditionFormula>AND (
	ISPICKVAL ( StageName , &quot;Closed Lost&quot;) ,
	ISPICKVAL ( Loss_Reason__c , &quot;&quot; ) ,
	ISBLANK ( Loss_Reason_Note__c)
)</errorConditionFormula>
        <errorMessage>Please select a Loss Reason and provide a short overview in the Loss Reason Notes.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Lock_Closed_Won_Loss_Except_SalesOps</fullName>
        <active>true</active>
        <description>Locks closed opportunities for everyone expect System Admin and Deb W (Sales Ops)</description>
        <errorConditionFormula>AND ( PRIORVALUE ( IsClosed ) = True,
	NOT ( 
		OR (  $Profile.Name = &quot;System Administrator&quot;,
		$User.Email = &quot;dvanwinkle@cenergistic.com&quot;,
		$User.Email = &quot;mdwivedi@cenergistic.com&quot;,
		$User.Email = &quot;ksyrus@cenergistic.com&quot;,
		$User.Email = &quot;mcaruso@cenergistic.com&quot;
		) 
	)
)</errorConditionFormula>
        <errorMessage>This Opportunity is closed. Please contact Sales Operations or CRM Admin if you have any questions.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Set_Contract_Start_Date</fullName>
        <active>true</active>
        <description>Requires an entry in the Contract Start Date field when stage set to Closed Won</description>
        <errorConditionFormula>AND (
ISPICKVAL (  StageName , &quot;Closed Won&quot; ),
ISBLANK (  Contract_Start_Date__c )
)</errorConditionFormula>
        <errorMessage>Enter the Contract Start Date.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>vsa__No_more_than_one_OAT</fullName>
        <active>false</active>
        <description>Only Allows one Opportunity Assessment per Opportunity</description>
        <errorConditionFormula>vsa__Count_of_Opportunity_Assessments_RO__c &gt;1</errorConditionFormula>
        <errorMessage>You have already created an Opportunity Assessment for this Opportunity.</errorMessage>
    </validationRules>
    <webLinks>
        <fullName>New_Opp</fullName>
        <availability>online</availability>
        <displayType>massActionButton</displayType>
        <encodingKey>UTF-8</encodingKey>
        <height>600</height>
        <linkType>url</linkType>
        <masterLabel>New Opp</masterLabel>
        <openType>sidebar</openType>
        <protected>false</protected>
        <requireRowSelection>true</requireRowSelection>
        <url>/lightning/o/Opportunity/new?defaultFieldValues=StageName=Discovery,AccountId={!Account.Id}</url>
    </webLinks>
