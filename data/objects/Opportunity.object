5,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__MutualPlan5&quot;, &quot;5 Mutual Plans&quot; , 50, 50)),
(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__MutualPlan6&quot;, &quot;More than 5 Mutual Plans&quot; , 50, 50))
))
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
