(CASE( vsa__Count_of_Mutual_Plans__c,
0,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__NoMutualPlan&quot;, &quot;No Mutual Plan Exists&quot; , 50, 50)),
1,(IMAGE(LEFT($Api.Partner_Server_URL_560, FIND( &apos;/services&apos;,$Api.Partner_Server_URL_560))&amp;&quot;resource/vsa__MutualPlan1&quot;, &quot;1 Mutual Plan&quot; , 50, 50)),
