    <label>Energy Program</label>
    <listViews>
        <fullName>Active</fullName>
        <columns>NAME</columns>
        <columns>Contract_Start_Date__c</columns>
        <columns>Organization__c</columns>
        <columns>Service_Status__c</columns>
        <columns>Contract_Status__c</columns>
        <columns>Related_Opportunity__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>LAST_UPDATE</columns>
        <columns>UPDATEDBY_USER</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Service_Status__c</field>
            <operation>equals</operation>
            <value>IC</value>
        </filters>
        <label>Active</label>
    </listViews>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
