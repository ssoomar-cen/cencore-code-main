    <fields>
        <fullName>Client_Manager__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Client Manager</label>
        <lookupFilter>
            <active>true</active>
            <booleanFilter>1 OR 2</booleanFilter>
            <errorMessage>You must select a person that is has the title Client Manager on their Salesforce user record. If you are unable to find the person that you are looking for, contact the CRM Administrator.</errorMessage>
            <filterItems>
                <field>User.Title</field>
                <operation>equals</operation>
                <value>Client Manager</value>
            </filterItems>
            <filterItems>
                <field>User.Title</field>
                <operation>equals</operation>
                <value>Regional Vice President</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>User</referenceTo>
