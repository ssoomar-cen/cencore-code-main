        <fullName>SharePoint_Path__c</fullName>
        <externalId>false</externalId>
        <formula>IF ( AND (  ISBLANK ( D365EnergyProgramGuid__c ),  DATEVALUE( CreatedDate ) &gt; DATE ( 2025,3,10 ) ), 
Name + &quot;_&quot; +  Id , 
Name + &quot;_&quot; +  D365EnergyProgramGuid__c )</formula>
        <inlineHelpText>Used for PDF Butler SharePoint integration to determine path to SharePoint file location.</inlineHelpText>
        <label>SharePoint Path</label>
        <required>false</required>
