        <columns>Related_Opportunity__c</columns>
        <columns>CREATED_DATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Service_Status__c</field>
            <operation>notEqual</operation>
            <value>IC</value>
        </filters>
        <label>All INACTIVE</label>
    </listViews>
    <listViews>
        <fullName>Copy_of_TEST_My_Dynamic_EPs</fullName>
        <booleanFilter>( 1 OR 2 OR 3 OR 4 OR 5 OR 6 OR 7 ) AND 8</booleanFilter>
