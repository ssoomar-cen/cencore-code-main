    <fields>
        <fullName>Unique_Contract_ID__c</fullName>
        <externalId>false</externalId>
        <formula>Customerid__c +  TEXT(Contract__r.Contract_Start_Date__c)</formula>
        <label>Unique Contract ID</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Unique_Invoice_Id__c</fullName>
        <externalId>false</externalId>
        <formula>Unique_Contract_ID__c  &amp; &apos;-&apos; &amp; TEXT(YEAR(Bill_Month__c)) &amp; &apos;-&apos; &amp; 
RIGHT(&apos;0&apos; &amp; TEXT(MONTH(Bill_Month__c)), 2) &amp; &apos;-&apos; &amp; 
RIGHT(&apos;0&apos; &amp; TEXT(DAY(Bill_Month__c)), 2) &amp; &apos;-&apos; &amp;  Invoice_ID__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Unique Invoice Id</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
