generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum ShareScope {
  PRIVATE
  TEAM
  ORG
}

// ============================================================================
// ENERGY CONSERVATION CRM ENUMS
// ============================================================================

enum SectorType {
  K12
  HIGHER_ED
  HEALTHCARE
  COMMERCIAL
  INDUSTRIAL
  MUNICIPAL
  MIXED_USE
}

enum DocumentKind {
  AUDIT_REPORT
  UTILITY_BILL
  FLOORPLAN
  PROPOSAL
  APPLICATION
  COMMISSIONING
  PHOTO
  CUSTOMER_APPROVAL
  CONTRACT
  OTHER
}

enum AssetCategory {
  HVAC
  LIGHTING
  ENVELOPE
  CONTROLS
  DHW
  REFRIGERATION
  MOTORS
  PLUG_LOAD
  RENEWABLE
  METERING
  OTHER
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  END_OF_LIFE
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  RETIRED
  REPLACED
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  role       UserRole
  teamId     String      @map("team_id")
  orgId      String      @map("org_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  savedViews         SavedView[]
  favorites          ViewFavorite[]
  auditLogs          AuditLog[]
  ownedPortfolios    Portfolio[]   @relation("PortfolioOwner")
  uploadedDocuments  Document[]    @relation("DocumentUploader")

  @@index([teamId])
  @@index([orgId])
  @@map("users")
}

model Account {
  id          String          @id @default(cuid())
  name        String
  industry    String?
  region      String?
  sector      SectorType?
  teamId      String          @map("team_id")
  orgId       String          @map("org_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Salesforce fields
  salesforceId        String?       @unique @map("salesforce_id")
  orgLegalName        String?       @map("org_legal_name")
  orgType             String?       @map("org_type")
  billingStreet       String?       @map("billing_street")
  billingCity         String?       @map("billing_city")
  billingState        String?       @map("billing_state")
  billingPostalCode   String?       @map("billing_postal_code")
  billingCountry      String?       @map("billing_country")
  phone               String?
  website             String?
  status              String?
  contractStatus      String?       @map("contract_status")

  opportunities       Opportunity[]
  contacts            Contact[]
  contracts           Contract[]
  energyPrograms      EnergyProgram[]
  invoices            Invoice[]
  portfolios          Portfolio[]
  buildings           Building[]

  @@index([industry])
  @@index([region])
  @@index([sector])
  @@index([teamId])
  @@index([orgId])
  @@index([salesforceId])
  @@map("accounts")
}

model Opportunity {
  id           String      @id @default(cuid())
  salesforceId String?     @unique @map("salesforce_id")
  name         String
  stage        String
  amount       Decimal?    @db.Decimal(14, 2)
  probability  Decimal?    @db.Decimal(5, 2)
  closeDate    DateTime?   @map("close_date")
  accountId    String      @map("account_id")
  ownerId      String?     @map("owner_id")
  teamId       String      @map("team_id")
  orgId       String       @map("org_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  account      Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  owner        User?       @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products     OpportunityProduct[]

  @@index([salesforceId])
  @@index([stage])
  @@index([closeDate])
  @@index([accountId])
  @@index([ownerId])
  @@index([teamId])
  @@index([orgId])
  @@index([stage, closeDate])
  @@map("opportunities")
}

model Contact {
  id         String      @id @default(cuid())
  firstName  String      @map("first_name")
  lastName   String      @map("last_name")
  email      String
  accountId  String      @map("account_id")
  teamId     String      @map("team_id")
  orgId      String      @map("org_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  account    Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@index([email])
  @@index([teamId])
  @@index([orgId])
  @@map("contacts")
}

model Product {
  id         String      @id @default(cuid())
  name       String
  sku        String      @unique
  family     String
  teamId     String      @map("team_id")
  orgId      String      @map("org_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  opportunities OpportunityProduct[]

  @@index([family])
  @@index([teamId])
  @@index([orgId])
  @@map("products")
}

model OpportunityProduct {
  id            String       @id @default(cuid())
  opportunityId String       @map("opportunity_id")
  productId     String       @map("product_id")
  quantity      Int
  unitPrice     Decimal      @map("unit_price") @db.Decimal(14, 2)

  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([opportunityId])
  @@index([productId])
  @@index([opportunityId, productId])
  @@map("opportunity_products")
}

model SavedView {
  id            String      @id @default(cuid())
  baseEntity    String      @map("base_entity")
  name          String
  description   String?
  scope         ShareScope
  ownerId       String      @map("owner_id")
  teamId        String      @map("team_id")
  orgId         String      @map("org_id")
  definition    Json
  isDefault     Boolean     @default(false) @map("is_default")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  favorites     ViewFavorite[]

  @@index([baseEntity])
  @@index([ownerId])
  @@index([scope])
  @@index([teamId])
  @@index([orgId])
  @@map("saved_views")
}

model ViewFavorite {
  id          String    @id @default(cuid())
  viewId      String    @map("view_id")
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  view        SavedView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([viewId, userId])
  @@index([userId])
  @@map("view_favorites")
}

model AuditLog {
  id          String    @id @default(cuid())
  actorId     String    @map("actor_id")
  action      String
  entity      String
  entityId    String?   @map("entity_id")
  payload     Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  actor       User      @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// CONTRACT & ENERGY PROGRAM MODELS
// ============================================================================

model Contract {
  id                      String              @id @default(cuid()) @map("contract_id")
  salesforceId            String?             @unique @map("salesforce_id")
  name                    String
  accountId               String              @map("account_id")

  // Contract Fields
  contractStatus          String?             @map("contract_status")
  contractType            String?             @map("contract_type")
  contractTerm            String?             @map("contract_term")
  contractStartDate       DateTime?           @map("contract_start_date")
  billingScheduleEndDate  DateTime?           @map("billing_schedule_end_date")

  // Client Management
  clientManager           String?             @map("client_manager")
  serviceStatus           String?             @map("service_status")

  // System Fields
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  // Relations
  account                 Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoices                Invoice[]

  @@index([accountId])
  @@index([salesforceId])
  @@index([contractStatus])
  @@map("contract")
}

model EnergyProgram {
  id                      String              @id @default(cuid()) @map("energy_program_id")
  salesforceId            String?             @unique @map("salesforce_id")
  name                    String
  accountId               String              @map("account_id")

  // Program Fields
  status                  String?
  pgmId                   String?             @map("pgm_id")

  // Technical Details
  technicalLead           String?             @map("technical_lead")
  implementationConsultant String?            @map("implementation_consultant")

  // Dates
  contractStartDate       DateTime?           @map("contract_start_date")
  billingScheduleEndDate  DateTime?           @map("billing_schedule_end_date")

  // System Fields
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  // Relations
  account                 Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoices                Invoice[]
  buildings               Building[]

  @@index([accountId])
  @@index([salesforceId])
  @@index([status])
  @@map("energy_program")
}

// ============================================================================
// INVOICE DOMAIN MODELS
// ============================================================================

model Invoice {
  id                    String              @id @default(cuid()) @map("invoice_id")
  tenantId              String              @map("tenant_id")
  accountId             String?             @map("account_id")
  contractId            String?             @map("contract_id")
  energyProgramId       String?             @map("energy_program_id")

  // Naming fields
  name                  String?
  invoiceName           String?             @map("invoice_name")
  invoiceNameTk         String?             @map("invoice_name_tk")
  invoiceNumber         String?             @map("invoice_number")
  invoiceSfNumber       String?             @map("invoice_sf_number")  // Invoice_ID__c from Salesforce
  itemId                String?             @map("item_id")
  customerId            String?             @map("customer_id")

  // Document type
  documentType          String?             @map("document_type")  // Invoice | Credit Memo | Debit Memo

  // Dates
  issueDate             DateTime?           @map("issue_date")
  dueDate               DateTime?           @map("due_date")
  billMonth             DateTime?           @map("bill_month")
  postDate              DateTime?           @map("post_date")
  scheduledDate         DateTime?           @map("scheduled_date")
  cycleEndDate          DateTime?           @map("cycle_end_date")
  dateDelivered         DateTime?           @map("date_delivered")
  appliedPaymentDate    DateTime?           @map("applied_payment_date")

  // Financials
  contractAmount        Decimal?            @db.Decimal(18, 0) @map("contract_amount")
  invoiceTotal          Decimal?            @db.Decimal(18, 0) @map("invoice_total")
  appliedAmount         Decimal?            @db.Decimal(18, 0) @map("applied_amount")
  creditTotal           Decimal?            @db.Decimal(18, 0) @map("credit_total")
  subtotalAmount        Decimal?            @default(0) @db.Decimal(15, 2) @map("subtotal_amount")
  taxAmount             Decimal?            @default(0) @db.Decimal(15, 2) @map("tax_amount")
  totalAmount           Decimal?            @db.Decimal(15, 2) @map("total_amount")
  currency              String?             @default("USD")

  // Status & Workflow
  status                String?             @default("Draft")
  intacctStatus         String?             @map("intacct_status")  // Paid | Partially Paid | Open | etc
  intacctState          String?             @map("intacct_state")   // Pending | Closed
  billingWizard         String?             @map("billing_wizard")  // Yes | No
  readyForBilling       String?             @map("ready_for_billing")  // Yes | No
  runReconciliation     String?             @map("run_reconciliation")  // Yes | No

  // External IDs
  generatedExternalId   String?             @unique @map("generated_external_id")
  salesforceId          String?             @map("salesforce_id")
  salesforceAccountId   String?             @map("salesforce_account_id")
  salesforceContractId  String?             @map("salesforce_contract_id")
  salesforceProjectId   String?             @map("salesforce_project_id")
  salesforceEnergyProgramId String?         @map("salesforce_energy_program_id")
  d365ContractId        String?             @map("d365_contract_id")
  d365EnergyProgramId   String?             @map("d365_energy_program_id")
  crgbiInvoiceId        String?             @map("crgbi_invoice_id")
  legacySource          String?             @map("legacy_source")

  // Business Central Integration
  bcId                  String?             @map("bc_id")
  bcNumber              String?             @map("bc_number")
  bcSyncStatus          String?             @default("pending") @map("bc_sync_status")
  bcLastSyncedAt        DateTime?           @map("bc_last_synced_at")

  // Misc
  notes                 String?
  description           String?
  salesforceRaw         String?             @map("salesforce_raw")  // JSON
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // Relations
  items                 InvoiceItem[]
  reconciliations       InvoiceRecon[]
  account               Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contract              Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  energyProgram         EnergyProgram?      @relation(fields: [energyProgramId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([accountId])
  @@index([contractId])
  @@index([energyProgramId])
  @@index([invoiceSfNumber])
  @@index([documentType])
  @@index([status])
  @@index([intacctStatus])
  @@unique([salesforceId])
  @@map("invoice")
}

model InvoiceItem {
  id                        String              @id @default(cuid()) @map("invoice_item_id")
  tenantId                  String              @map("tenant_id")
  invoiceId                 String              @map("invoice_id")  // MasterDetail → invoice
  projectId                 String?             @map("project_id")
  energyProgramId           String?             @map("energy_program_id")

  // Naming
  name                      String?

  // Classification
  invoiceItemType           String?             @map("invoice_item_type")

  // Dates
  periodDate                DateTime?           @map("period_date")

  // Financials (all from Invoice_Item_CEN__c)
  feeAmount                 Decimal?            @db.Decimal(17, 2) @map("fee_amount")
  credit                    Decimal?            @db.Decimal(17, 2)
  currentCostAvoidance      Decimal?            @db.Decimal(17, 2) @map("current_cost_avoidance")
  previousCostAvoidance     Decimal?            @db.Decimal(17, 2) @map("previous_cost_avoidance")
  specialSavings            Decimal?            @db.Decimal(17, 2) @map("special_savings")
  previousSpecialSavings    Decimal?            @db.Decimal(17, 2) @map("previous_special_savings")
  currentLessPrevious       Decimal?            @db.Decimal(17, 2) @map("current_less_previous")
  savings                   Decimal?            @db.Decimal(18, 8)

  // External IDs
  salesforceId              String?             @map("salesforce_id")
  salesforceInvoiceId       String?             @map("salesforce_invoice_id")
  salesforceProjectId       String?             @map("salesforce_project_id")
  salesforceEnergyProgramId String?             @map("salesforce_energy_program_id")
  d365InvoiceItemGuid       String?             @unique @map("d365_invoice_item_guid")

  salesforceRaw             String?             @map("salesforce_raw")  // JSON
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  // Relations
  invoice                   Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reconciliations           InvoiceRecon[]

  @@index([tenantId])
  @@index([invoiceId])
  @@index([projectId])
  @@index([energyProgramId])
  @@unique([salesforceId])
  @@map("invoice_item")
}

model InvoiceRecon {
  id                      String              @id @default(cuid()) @map("invoice_recon_id")
  tenantId                String              @map("tenant_id")
  invoiceItemId           String              @map("invoice_item_id")  // FK to invoice_item
  invoiceId               String?             @map("invoice_id")  // Denormalized for query efficiency

  // Organization / Location
  orgName                 String?             @map("org_name")
  placeInfo               String?             @map("place_info")
  logicalDeviceCode       String?             @map("logical_device_code")

  // Dates
  reportDate              DateTime?           @map("report_date")
  beginDate               DateTime?           @map("begin_date")

  // Classification
  category                String?             // New | Old | etc

  // Financial Data
  currentBatcc            Decimal?            @db.Decimal(15, 2) @map("current_batcc")
  previousBatcc           Decimal?            @db.Decimal(15, 2) @map("previous_batcc")
  currentActualCost       Decimal?            @db.Decimal(15, 2) @map("current_actual_cost")
  previousActualCost      Decimal?            @db.Decimal(15, 2) @map("previous_actual_cost")
  currentCa               Decimal?            @db.Decimal(15, 2) @map("current_ca")
  previousCa              Decimal?            @db.Decimal(15, 2) @map("previous_ca")

  // References
  energyProgramId         String?             @map("energy_program_id")
  salesDocName            String?             @map("sales_doc_name")
  placeId                 String?             @map("place_id")
  invoiceItemName         String?             @map("invoice_item_name")
  salesforceId            String?             @map("salesforce_id")

  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  // Relations
  invoiceItem             InvoiceItem         @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  invoice                 Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceItemId])
  @@index([invoiceId])
  @@index([reportDate])
  @@index([energyProgramId])
  @@map("invoice_recon")
}

// ============================================================================
// ENERGY CONSERVATION CRM — PORTFOLIO & BUILDING HIERARCHY
// ----------------------------------------------------------------------------
// Portfolio groups a customer's buildings for portfolio selling, benchmarking,
// and rollup reporting (e.g. a school district, a hospital system, a REIT).
// Campus is an optional physical grouping beneath a Portfolio (e.g. a
// university campus with multiple buildings). Buildings may belong directly
// to a Portfolio without a Campus.
// ============================================================================

model Portfolio {
  id            String       @id @default(cuid()) @map("portfolio_id")
  tenantId      String       @map("tenant_id")
  accountId     String       @map("account_id")
  ownerUserId   String?      @map("owner_user_id")

  name          String
  description   String?
  sector        SectorType?

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner         User?        @relation("PortfolioOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  campuses      Campus[]
  buildings     Building[]

  @@index([tenantId])
  @@index([accountId])
  @@index([ownerUserId])
  @@index([sector])
  @@map("portfolio")
}

model Campus {
  id            String       @id @default(cuid()) @map("campus_id")
  tenantId      String       @map("tenant_id")
  portfolioId   String       @map("portfolio_id")

  name          String
  description   String?

  // Location
  addressLine1  String?      @map("address_1")
  addressLine2  String?      @map("address_2")
  city          String?
  state         String?
  zip           String?
  country       String?      @default("US")
  latitude      Decimal?     @db.Decimal(10, 7)
  longitude     Decimal?     @db.Decimal(10, 7)
  climateZone   String?      @map("climate_zone")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  portfolio     Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  buildings     Building[]

  @@index([tenantId])
  @@index([portfolioId])
  @@map("campus")
}

// ============================================================================
// Building — first-class energy-conservation entity.
// Column names intentionally match the pre-existing Supabase `building` table
// consumed by useBuildings.tsx so the hook/UI keeps working when Prisma takes
// over. New energy-CRM fields (portfolio/campus linkage, benchmarking, climate
// zone, operating hours, square-foot variants) are additive.
// ============================================================================

model Building {
  id                  String         @id @default(cuid()) @map("building_id")
  tenantId            String         @map("tenant_id")
  accountId           String         @map("account_id")
  portfolioId         String?        @map("portfolio_id")
  campusId            String?        @map("campus_id")
  energyProgramId     String?        @map("energy_program_id")
  projectId           String?        @map("project_id")

  // Identity
  name                String
  buildingNo          String?        @map("building_no")
  salesforceId        String?        @map("salesforce_id")

  // Address (column names preserve existing Supabase table shape)
  addressLine1        String?        @map("address_1")
  addressLine2        String?        @map("address_2")
  city                String?
  state               String?
  zip                 String?
  country             String?        @default("US")
  latitude            Decimal?       @db.Decimal(10, 7)
  longitude           Decimal?       @db.Decimal(10, 7)

  // Classification
  primaryUse          String?        @map("primary_use")
  sector              SectorType?
  status              String?
  statusReason        String?        @map("status_reason")

  // Physical characteristics
  squareFootage       Int?           @map("square_footage")
  grossSqFt           Int?           @map("gross_sq_ft")
  netSqFt             Int?           @map("net_sq_ft")
  floors              Int?
  yearBuilt           Int?           @map("year_built")
  yearRenovated       Int?           @map("year_renovated")
  occupancyType       String?        @map("occupancy_type")
  operatingHours      Json?          @map("operating_hours")
  climateZone         String?        @map("climate_zone")

  // Benchmarking
  energyStarId        String?        @map("energy_star_id")
  energyStarScore     Int?           @map("energy_star_score")
  eui                 Decimal?       @db.Decimal(10, 2)
  targetEui           Decimal?       @db.Decimal(10, 2) @map("target_eui")

  // Integration IDs (preserved for Salesforce / d365 / ECAP / Greenx compat)
  placeCode           String?        @map("place_code")
  placeId             String?        @map("place_id")
  ecapBuildingId      String?        @map("ecap_building_id")
  ecapOwner           String?        @map("ecap_owner")
  buildingD365Id      String?        @map("building_d365_id")
  measureBuildingId   String?        @map("measure_building_id")
  excludeFromGreenx   Boolean?       @map("exclude_from_greenx")
  db                  String?

  // Misc
  notes               String?

  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  account             Account        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  portfolio           Portfolio?     @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  campus              Campus?        @relation(fields: [campusId], references: [id], onDelete: SetNull)
  energyProgram       EnergyProgram? @relation(fields: [energyProgramId], references: [id], onDelete: SetNull)
  assets              Asset[]

  @@index([tenantId])
  @@index([accountId])
  @@index([portfolioId])
  @@index([campusId])
  @@index([energyProgramId])
  @@index([projectId])
  @@index([salesforceId])
  @@index([city, state])
  @@index([primaryUse])
  @@index([sector])
  @@index([status])
  @@map("building")
}

// ============================================================================
// Document — polymorphic attachment record.
// Metadata only: the binary lives in Supabase Storage (or another provider
// keyed by `storage_provider`) at `bucket`/`storage_key`. Linked to any parent
// entity via `parent_type` + `parent_id` — we intentionally avoid per-entity
// join tables to keep the surface small. Routes should issue short-lived
// signed URLs rather than exposing the storage key directly.
// ============================================================================

model Document {
  id               String        @id @default(cuid()) @map("document_id")
  tenantId         String        @map("tenant_id")

  kind             DocumentKind
  title            String?
  description      String?

  // Storage
  storageProvider  String        @default("SUPABASE") @map("storage_provider")
  bucket           String
  storageKey       String        @map("storage_key")
  filename         String
  contentType      String?       @map("content_type")
  sizeBytes        BigInt?       @map("size_bytes")
  sha256           String?

  // Polymorphic parent — set both or neither.
  parentType       String?       @map("parent_type")
  parentId         String?       @map("parent_id")

  uploadedById     String?       @map("uploaded_by_id")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  uploadedBy       User?         @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  assetPhotos      Asset[]       @relation("AssetPhoto")

  @@index([tenantId])
  @@index([parentType, parentId])
  @@index([uploadedById])
  @@index([kind])
  @@index([sha256])
  @@map("document")
}

// ============================================================================
// Asset — physical equipment living in a Building (RTU, chiller, boiler,
// lighting fixture, envelope component, BAS controller, etc). Anchors audit
// findings and ECMs to real equipment, and carries just enough make/model /
// life / condition data to drive replacement planning and savings estimates.
//
// Photos: `photoDocId` points at a single primary photo in `Document`;
// additional photos live polymorphically with `Document.parent_type = 'Asset'`
// + `parent_id = asset.id`. Sector-specific fields (e.g. HVAC tons per ton of
// cooling, classroom ID for K-12, criticality for healthcare) live in
// `AssetSectorExtension` so the core table stays thin.
// ============================================================================

model Asset {
  id                String                @id @default(cuid()) @map("asset_id")
  tenantId          String                @map("tenant_id")
  buildingId        String                @map("building_id")

  // Identity
  name              String
  assetTag          String?               @map("asset_tag")

  // Classification
  category          AssetCategory
  subtype           String?

  // Location within building
  location          String?
  floor             String?
  zone              String?

  // Make / provenance
  manufacturer      String?
  model             String?
  serialNumber      String?               @map("serial_number")

  // Lifecycle
  installYear       Int?                  @map("install_year")
  expectedLifeYears Int?                  @map("expected_life_years")
  lastServiceDate   DateTime?             @map("last_service_date")

  // Rating
  capacity          Decimal?              @db.Decimal(14, 4)
  capacityUnit      String?               @map("capacity_unit")

  // State
  condition         AssetCondition?
  status            AssetStatus?          @default(ACTIVE)

  // Economics
  replacementCost   Decimal?              @map("replacement_cost") @db.Decimal(14, 2)

  // Primary photo
  photoDocId        String?               @map("photo_doc_id")

  // Arbitrary extras
  metadata          Json?

  notes             String?

  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  // Relations
  building          Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  photo             Document?             @relation("AssetPhoto", fields: [photoDocId], references: [id], onDelete: SetNull)
  sectorExtension   AssetSectorExtension?

  @@index([tenantId])
  @@index([buildingId])
  @@index([category])
  @@index([subtype])
  @@index([condition])
  @@index([status])
  @@index([assetTag])
  @@map("asset")
}

// ============================================================================
// AssetSectorExtension — 1:1 side table carrying sector-specific fields so the
// Asset core stays thin. `data` is a JSON blob validated app-side against a
// schema keyed by `sector` + `schemaVersion`. Keeping this in its own row
// makes it easy to evolve sector schemas without touching the Asset table.
// ============================================================================

model AssetSectorExtension {
  id            String     @id @default(cuid()) @map("asset_sector_extension_id")
  assetId       String     @unique @map("asset_id")
  tenantId      String     @map("tenant_id")

  sector        SectorType
  schemaVersion String?    @map("schema_version")
  data          Json

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  asset         Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sector])
  @@map("asset_sector_extension")
}
