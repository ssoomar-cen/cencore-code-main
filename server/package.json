{
  "name": "cencore-view-builder-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore \"../**\" src/index.ts",
    "dev:single": "cross-env NODE_ENV=development SERVE_FRONTEND=true tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "start:single": "cross-env NODE_ENV=production SERVE_FRONTEND=true node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "import:accounts": "tsx src/scripts/import-accounts.ts",
    "import:contracts": "tsx src/scripts/import-contracts.ts",
    "import:energy-programs": "tsx src/scripts/import-energy-programs.ts",
    "import:invoices": "tsx src/scripts/import-invoices.ts",
    "import:invoice-items": "tsx src/scripts/import-invoice-items.ts",
    "import:reconciliation": "tsx src/scripts/import-reconciliation.ts",
    "import:buildings": "tsx src/scripts/import-buildings.ts",
    "import:all": "npm run import:accounts && npm run import:contracts && npm run import:energy-programs && npm run import:invoices && npm run import:invoice-items && npm run import:reconciliation && npm run import:buildings",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.5",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.20.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.19",
    "vitest": "^3.0.5"
  }
}
